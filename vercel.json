{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/dental-implants",
      "dest": "/dental-implants.html"
    },
    {
      "src": "/emergency-dentistry",
      "dest": "/emergency-dentistry.html"
    },
    {
      "src": "/invisalign",
      "dest": "/invisalign.html"
    },
    {
      "src": "/restorative-dentistry",
      "dest": "/restorative-dentistry.html"
    },
    {
      "src": "/teeth-whitening",
      "dest": "/teeth-whitening.html"
    },
    {
      "src": "/veneers",
      "dest": "/veneers.html"
    },
    {
      "src": "/insurance-checker",
      "dest": "/insurance-checker-ahdd__4_.html"
    },
    {
      "src": "/chatbot",
      "dest": "/chatbot-widget-updated.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
